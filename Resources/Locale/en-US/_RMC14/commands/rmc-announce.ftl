rmc-command-marineannounce-description = Send an in-game announcement.
rmc-command-marineannounce-help = <rmcannounce> <sender> <message> or <rmcannounce> <message> to send announcement as High Command.

rmc-command-aresannounce-description = Send an in-game announcement as the ARES core. Beware, this will work even if the ARES core is destroyed! Please make sure it isn't before you use this.
rmc-command-aresannounce-help = <aresannounce> <message> to send an announcement as ARES. Beware, this will work even if the ARES core is destroyed! Please make sure it isn't before you use this.

