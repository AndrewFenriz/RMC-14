<controls:EvacuationComputerWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Marines.Evacuation"
    xmlns:ui="clr-namespace:Content.Client._RMC14.UserInterface"
    Title="{Loc 'rmc-evac-computer-title'}">
    <BoxContainer Orientation="Vertical">
        <RichTextLabel Text="{Loc 'rmc-evac-computer-info-display'}" />
        <ui:BlueHorizontalSeparator />
        <Label Name="StatusLabel" Access="Public" Text="{Loc 'rmc-evac-computer-status-none'}" />
        <Label Name="HatchLabel" Access="Public" Text="{Loc 'rmc-evac-computer-hatch-unsecured'}" />
        <RichTextLabel Text="{Loc 'rmc-evac-computer-pod-controls'}" Margin="0 10 0 0" />
        <ui:BlueHorizontalSeparator />
        <Button Name="DoorButton" Access="Public" Text="{Loc 'rmc-evac-computer-unlock-door'}" StyleClasses="OpenBoth" />
        <Button Name="EjectButton" Access="Public" Text="{Loc 'rmc-evac-computer-manual-eject'}" StyleClasses="OpenBoth" />
        <Button Name="DelayButton" Access="Public" Text="{Loc 'rmc-evac-computer-delay-launch'}" StyleClasses="OpenBoth" />
    </BoxContainer>
</controls:EvacuationComputerWindow>
